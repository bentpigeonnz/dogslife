rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User Profiles - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Dogs - public read, only Admin or Shelter Manager can write
    match /dogs/{dogId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.role == 'Admin' ||
        request.auth.token.role == 'Shelter Manager'
      );
    }

    // Adoptions - users can create their own application, Admin/Manager can read/manage
    match /adoptions/{adoptionId} {
      allow create: if request.auth != null;

      allow read, update, delete: if request.auth != null && (
        request.auth.token.role == 'Admin' ||
        request.auth.token.role == 'Shelter Manager'
      );
    }

    // Events - public read, Admin/Manager can create/manage
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.role == 'Admin' ||
        request.auth.token.role == 'Shelter Manager'
      );
    }

    // Merchandise - public read, Admin can create/manage
    match /merchandise/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'Admin';
    }

    // Donations - Admin can manage donation records, no public read
    match /donations/{donationId} {
      allow write, read: if request.auth != null && request.auth.token.role == 'Admin';
    }
  }
}
